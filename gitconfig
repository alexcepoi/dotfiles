[user]
    name = Alex Cepoi
    email = alex.cepoi@gmail.com
[github]
    user = alexcepoi
[core]
    pager = less -+F -+X -c
    excludesfile = ~/.gitignore_global
[push]
    default = simple
[branch]
    autosetuprebase = always
[status]
    short = true
[color]
    ui = true
[alias]
    alias = config --get-regexp ^alias.
    amend = commit --amend --reuse-message=HEAD --reset-author
    stat = diff --stat
    pending = branch --sort=-committerdate --format='%(HEAD) %(align:30)%(color:yellow)%(refname:short)%(color:reset)%(end) %(committerdate:relative)' --no-merged master
    s = status
    st = diff --stat
    d = diff
    l = log --stat
[pager]
    stat = false
    st = false
    pending = false
[include]
    path = .gitconfig.local
