[user]
    name = Alex Cepoi
    email = alex.cepoi@gmail.com
[github]
    user = alexcepoi
[core]
    pager = less -+F -+X -c
    excludesfile = ~/.gitignore_global
[push]
    default = simple
[branch]
    autosetuprebase = always
[color]
    ui = true
[alias]
    alias = config --get-regexp ^alias.
    amend = commit --amend --reuse-message=HEAD --reset-author
    stat = diff --stat
[pager]
    stat = false
[include]
    path = .gitconfig.local
