[ui]
username = alexcepoi
verbose = true
merge = internal:merge3
ignore = ~/.hgignore_global

[defaults]
log = --follow
push = --branch . --new-branch

[pager]
pager = less -+F -+X -c
attend-help = true
attend-xl = true
attend-ll = true
attend-pdiff = true

[extensions]
color =
extdiff =
graphlog =
histedit =
mq =
pager =
progress =
purge =
rebase =
shelve =

[google_hgext]
pickcheckout.enable_curses_ui = true
